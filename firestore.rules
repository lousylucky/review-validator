rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin(salonId) {
      let salon = get(/databases/$(database)/documents/salons/$(salonId)).data;
      return request.auth != null
        && request.auth.token.email in salon.adminEmail;
    }

    // Salons — każdy może czytać (potrzebne przed logowaniem), nikt nie może pisać (tylko admin w Console)
    match /salons/{salonId} {
      allow read: if true;
      allow write: if false;

      // Coupons
      match /coupons/{couponId} {
        allow read: if request.auth != null
          && (request.auth.uid == couponId || isAdmin(salonId));

        allow create: if request.auth != null
          && request.auth.uid == couponId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'pending';

        allow update: if isAdmin(salonId);
        allow delete: if isAdmin(salonId);
      }
    }

    // Mail — każdy zalogowany może tworzyć (trigger email extension), nikt nie czyta
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Wszystko inne — zablokowane
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
